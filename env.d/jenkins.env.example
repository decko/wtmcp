# Jenkins plugin configuration
#
# Copy this file to jenkins.env and uncomment the variables you need:
#   cp jenkins.env.example jenkins.env
#
# For security, consider encrypting with Ansible Vault:
#   ansible-vault encrypt jenkins.env

# Jenkins instance URL (used as default if not specified in tool calls)
#JENKINS_URL=https://jenkins.example.com

# Auth type: auto, user-token, bearer-token, kerberos
# "auto" automatically selects based on available credentials.
#JENKINS_AUTH_TYPE=auto

# --- Username + API Token (most common) ---
# Your Jenkins username
#JENKINS_USER=your-username

# API token from Jenkins > User > Configure > API Token
# Get your token: Click your username (top-right) > Configure > API Token > Add new token
#JENKINS_TOKEN=your-api-token-from-jenkins

# --- Bearer Token (OAuth2 proxy) ---
# Uncomment if Jenkins is behind an OAuth2 proxy
# Set JENKINS_AUTH_TYPE=bearer-token
#JENKINS_TOKEN=your-bearer-token

# --- Kerberos (enterprise) ---
# Kerberos uses your existing ticket (kinit)
# Set JENKINS_AUTH_TYPE=kerberos
# No credentials needed - uses system Kerberos ticket

# --- Example Configurations ---

# Example 1: Standard Jenkins with API token
# JENKINS_USER=jdoe
# JENKINS_TOKEN=11234567890abcdef1234567890abcdef

# Example 2: Jenkins behind OAuth2 proxy
# JENKINS_AUTH_TYPE=bearer-token
# JENKINS_TOKEN=ya29.a0AfH6SMBx...

# Example 3: Enterprise Jenkins with Kerberos
# JENKINS_AUTH_TYPE=kerberos
# (No credentials needed, uses kinit ticket)

# --- Security Notes ---
#
# 1. Use Ansible Vault to encrypt this file:
#    ansible-vault encrypt ~/.config/wtmcp/env.d/jenkins.env
#
# 2. Prefer API tokens over passwords:
#    - API tokens can be scoped and revoked independently
#    - They don't grant Jenkins UI login access
#
# 3. For Kerberos deployments:
#    - No credentials stored in this file
#    - Uses your kinit ticket (most secure)
#
# 4. File permissions:
#    chmod 600 ~/.config/wtmcp/env.d/jenkins.env
