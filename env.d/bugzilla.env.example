# Bugzilla plugin configuration
#
# Copy this file to bugzilla.env and uncomment the variables you need:
#   cp bugzilla.env.example bugzilla.env
#
# Authentication is handled by the core HTTP proxy. The API key is
# not passed to the plugin process.

# BUGZILLA_URL: Base URL of your Bugzilla instance
#BUGZILLA_URL=https://bugzilla.redhat.com

# BUGZILLA_API_KEY: API key for authentication
# Generate at: <your-bugzilla-url>/userprefs.cgi?tab=apikey
#BUGZILLA_API_KEY=your-api-key-here
